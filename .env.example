# =============================================================================
# Afro Miaam — environment template
# =============================================================================
# Copy to `.env` on the VPS, fill in REAL values, then `chmod 600 .env`.
# NEVER commit the filled-in .env. Placeholders marked CHANGEME must be
# replaced. Generate strong secrets with:  openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# The app connects over the internal Docker network using the service name
# `postgres` as the host. The credentials below MUST match POSTGRES_* so the
# DATABASE_URL resolves to the same database the container creates.
DATABASE_URL=postgresql://afro:CHANGEME@postgres:5432/afromiaam
POSTGRES_USER=afro
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=afromiaam

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Symmetric secret used to sign/verify session JWTs. REQUIRED.
#   openssl rand -hex 32
AUTH_JWT_SECRET=CHANGEME

# Google OAuth 2.0 credentials (Google Cloud Console > Credentials).
# Authorized redirect URI must be:
#   https://afromiaam.com/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=CHANGEME
GOOGLE_OAUTH_CLIENT_SECRET=CHANGEME

# Public base URL of the site (used for absolute links, OAuth, emails).
NEXT_PUBLIC_SITE_URL=https://afromiaam.com
# Base URL used to build OAuth redirect URIs (usually == site URL).
OAUTH_REDIRECT_BASE_URL=https://afromiaam.com

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=CHANGEME
# From address for transactional/order emails (must be a verified domain).
EMAIL_FROM="Afro Miaam <commandes@afromiaam.com>"
# Inbox that receives restaurant-side notifications (new orders, contact form).
RESTAURANT_EMAIL=bonjour@afromiaam.com

# -----------------------------------------------------------------------------
# reCAPTCHA (v3)
# -----------------------------------------------------------------------------
# Site key is exposed to the browser; secret key stays server-side.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=CHANGEME
RECAPTCHA_SECRET_KEY=CHANGEME

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
# Directory inside the app container where menu images are written. Backed by
# the `uploads` Docker volume and served by Caddy at /uploads/*. Keep in sync
# with the volume mount in docker-compose.yml.
UPLOAD_DIR=/app/uploads

# -----------------------------------------------------------------------------
# Maintenance mode
# -----------------------------------------------------------------------------
# When true, the site shows a maintenance page to the public.
MAINTENANCE_MODE=false
# Secret query/cookie key that lets staff bypass maintenance mode.
#   openssl rand -hex 32
MAINTENANCE_BYPASS_KEY=CHANGEME

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production

# Tells clientIp() which reverse proxy is in front, so per-IP rate limits work.
# In our self-hosted stack Caddy proxies to the Next.js container.
# MUST stay "caddy" in production; without it, per-IP rate limiting collapses
# to a single shared bucket (DoS risk).
TRUSTED_PROXY=caddy
