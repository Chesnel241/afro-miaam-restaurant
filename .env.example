# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — used by the Next.js app to connect to the DB.
DATABASE_URL=postgresql://afro:STRONG_PASSWORD@postgres:5432/afromiaam

# PostgreSQL container credentials (used by the postgres Docker service)
POSTGRES_USER=afro
POSTGRES_PASSWORD=STRONG_PASSWORD
POSTGRES_DB=afromiaam

# ─── Email ───────────────────────────────────────────────────────────────────
# Resend API key — get one at https://resend.com (free: 3000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Address that receives order alert emails
RESTAURANT_EMAIL=bonjour@afro-miaam.fr

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
