rules_version = '2';

// =============================================================================
// AFRO MIAAM — STORAGE SECURITY RULES (HARDENED)
// =============================================================================
// Findings closed:
//   C1  — Public/authenticated arbitrary upload. Menu images: admin-only write,
//         5 MiB cap, content-type must be image/*. Everything else: deny by default
//         (no broad authenticated read).
// =============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Menu images: public read, admin upload + delete with strict validation.
    match /menu/{allPaths=**} {
      allow read: if true;

      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow delete: if isAdmin();
    }

    // Default-deny everything else. No broad authenticated read.
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
