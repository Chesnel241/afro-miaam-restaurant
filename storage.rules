rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /menu/{allPaths=**} {
      // Lecture publique pour le menu
      allow read: if true;
      
      // Seul l'admin peut uploader (écriture)
      allow write: if request.auth != null;
    }
    
    // Règles par défaut pour le reste
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
