rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS ---
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // --- USERS ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // H1 Fix: Whitelist des champs modifiables par le client
      allow update: if (isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'phone', 'isFirstLogin', 'image'])) || isAdmin();
    }

    // --- ORDERS ---
    match /orders/{orderId} {
      // C2 Fix: Validation stricte à la création
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "Attente Acompte"
        && request.resource.data.total is number
        && request.resource.data.total > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.createdAt == request.time;
        
      allow read: if isAdmin() || (isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.userEmail.lower() == request.auth.token.email.lower()
      ));
      
      // M3 Fix: Interdire la modification de la date dans le passé via rules (best effort)
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    // --- MENU ---
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- NEWSLETTER ---
    match /newsletter/{docId} {
      // H2 Fix: Validation format email
      allow create: if true 
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
      allow read: if isAdmin();
    }

    // --- PRESTATIONS ---
    match /prestations/{docId} {
      // C3 Fix: Protection contre le flood
      allow create: if isAuthenticated()
        && request.resource.data.email is string
        && request.resource.data.name is string;
      allow read, update: if isAdmin();
    }

    // --- SETTINGS ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
