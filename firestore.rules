rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Fonctions utilitaires ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ─── Profils utilisateurs ───
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == "customer";
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;
      allow update: if isAdmin();
    }

    // ─── Commandes ───
    match /orders/{orderId} {
      // Tout le monde peut créer une commande
      allow create: if true;

      // Un client peut lire SES commandes (soit par son ID, soit par son E-mail vérifié)
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.userEmail.lower() == request.auth.token.email.lower())
      );

      // L'admin peut tout lire
      allow read: if isAdmin();

      // Seul l'admin peut mettre à jour
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ─── Menu ───
    match /menu/{menuItemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Newsletter ───
    match /newsletter/{emailId} {
      allow create: if true 
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ─── Demandes de Prestation ───
    match /prestations/{prestationId} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if false;
    }
  }
}
