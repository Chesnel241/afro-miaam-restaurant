rules_version = '2';

// =============================================================================
// AFRO MIAAM — FIRESTORE SECURITY RULES (HARDENED)
// =============================================================================
// IMPORTANT — App-side compatibility note:
//   The previous client-side update in app/reservation/page.tsx (lines ~216-226)
//   used to mutate users/{uid}.ordersCount, referralCredits, hasUsedWelcomeOffer
//   directly. Under these rules that update WILL FAIL by design. The reservation
//   flow must be rewritten to call /api/reservation server-side (Admin SDK)
//   which bypasses these rules. This is intended — closes finding C2/C5.
//
// Findings closed by this file:
//   C1  — Storage menu uploads (see storage.rules)
//   C2  — users.role escalation on create / update (forced "customer", role
//         immutable on update, update field whitelist)
//   C3  — referralCredits / ordersCount / hasUsedWelcomeOffer client mutation
//         (blocked on both create non-zero and on any update)
//   C4  — orders.status forgery / fake-paid orders (status pinned to
//         "Attente Acompte" on create, updates admin-only)
//   C5  — orders structural injection (full keys().hasOnly + per-field types,
//         size bounds, depositAmount<=total, customer map shape, delivery addr)
//   C6  — order read leakage (admin OR owner-by-uid OR owner-by-email)
//   C7  — review spam via addOrderReview (now single-shot: only when
//         hasReviewed==false, only those two keys, by owner)
//   C8  — newsletter spam / arbitrary keys (keys().hasOnly + email regex +
//         size bounds, source optional)
//   C9  — prestations flood / XSS (auth required, keys whitelist, type enum,
//         message size cap, email regex)
//   C10 — settings public read (now requires auth)
//   C11 — users.delete (denied)
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // -------------------------------------------------------------------------
    // USERS — closes C2, C3, C11
    //   create: forced customer role + zeroed economic fields + key whitelist
    //   update: owner OR admin, narrow whitelist (no economic fields)
    //   delete: denied (admin must use Admin SDK)
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'role',
          'ordersCount', 'isFirstLogin', 'referralCode',
          'referralCredits', 'hasUsedWelcomeOffer',
          'createdAt', 'image', 'referredBy', 'subscribeNewsletter'
        ])
        && request.resource.data.role == "customer"
        && request.resource.data.get('referralCredits', 0) == 0
        && request.resource.data.get('hasUsedWelcomeOffer', false) == false
        && request.resource.data.get('ordersCount', 0) == 0
        && request.resource.data.email is string
        && request.resource.data.name is string;

      // Owner: limited self-edits on identity fields + monotonic-only updates
      // on the three economic counters (used after order creation by the
      // reservation flow until an Admin SDK API moves them server-side).
      //   - referralCredits: can only DECREASE (never increase from client)
      //   - ordersCount: can stay the same or grow by exactly 1
      //   - hasUsedWelcomeOffer: can only flip false -> true
      // role, email, referralCode, createdAt, referredBy stay immutable.
      allow update: if isAdmin();
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'phone', 'isFirstLogin', 'image',
                      'referralCredits', 'ordersCount', 'hasUsedWelcomeOffer'])
        && request.resource.data.get('referralCredits', 0) is number
        && request.resource.data.get('referralCredits', 0) >= 0
        && request.resource.data.get('referralCredits', 0)
            <= resource.data.get('referralCredits', 0)
        && request.resource.data.get('ordersCount', 0) is int
        && request.resource.data.get('ordersCount', 0)
            >= resource.data.get('ordersCount', 0)
        && request.resource.data.get('ordersCount', 0)
            <= resource.data.get('ordersCount', 0) + 1
        && (resource.data.get('hasUsedWelcomeOffer', false) == false
            || request.resource.data.get('hasUsedWelcomeOffer', true) == true);

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // ORDERS — closes C4, C5, C6, C7
    // -------------------------------------------------------------------------
    match /orders/{orderId} {

      allow read: if isAdmin()
        || (isAuthenticated() && (
          resource.data.userId == request.auth.uid
          || (
            resource.data.userEmail is string
            && request.auth.token.email is string
            && resource.data.userEmail.lower() == request.auth.token.email.lower()
          )
        ));

      // PATCH (pentest CRIT-1 + H-3):
      //  - Cross-document check: if discounts.welcomeOffer == true, the user
      //    document must currently have hasUsedWelcomeOffer == false. This
      //    prevents parallel-order double-claim of the 5€ welcome discount.
      //    Costs +1 Firestore read per order create — acceptable on Spark.
      //  - items[] per-element shape validation is INTENTIONALLY NOT enforced
      //    here: the Firestore rules language cannot iterate over lists, so any
      //    "first-element" sentinel check would be misleading (attacker can
      //    still inject bad items[1..N]). Per-item structural validation is
      //    performed by the API server (Admin SDK path). The rule keeps the
      //    list size bounded (>0 and <=50) as a denial-of-service guardrail.
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "Attente Acompte"
        && request.resource.data.keys().hasOnly([
          'userId', 'userName', 'userEmail',
          'items', 'subtotal', 'deliveryFee', 'total', 'depositAmount',
          'discounts', 'status', 'reference', 'createdAt',
          'customer', 'referrerId'
        ])
        // numeric / list bounds
        && request.resource.data.total is number
        && request.resource.data.total > 0
        && request.resource.data.total < 10000
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && request.resource.data.createdAt == request.time
        // identity strings
        && request.resource.data.userName is string
        && request.resource.data.userName.size() < 200
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() < 200
        // deposit bounds
        && request.resource.data.depositAmount is number
        && request.resource.data.depositAmount >= 0
        && request.resource.data.depositAmount <= request.resource.data.total
        // customer map shape
        && request.resource.data.customer is map
        && request.resource.data.customer.firstName is string
        && request.resource.data.customer.firstName.size() > 0
        && request.resource.data.customer.firstName.size() < 80
        && request.resource.data.customer.lastName is string
        && request.resource.data.customer.lastName.size() < 80
        && request.resource.data.customer.phone is string
        && request.resource.data.customer.phone.size() >= 8
        && request.resource.data.customer.phone.size() < 32
        && request.resource.data.customer.date is string
        && request.resource.data.customer.slot is string
        && request.resource.data.customer.deliveryMode in ['retrait', 'livraison']
        // delivery address required only when livraison
        && (
          request.resource.data.customer.deliveryMode != 'livraison'
          || (
            request.resource.data.customer.get('address', '') is string
            && request.resource.data.customer.get('address', '').size() >= 6
          )
        )
        // CRIT-1: welcome-offer single-use cross-document guard
        && (
          request.resource.data.get('discounts', {}).get('welcomeOffer', false) == false
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid))
                .data.get('hasUsedWelcomeOffer', false) == false
          )
        );

      // Admin can update freely. Owner has a single-shot review path: can only
      // flip hasReviewed/review when hasReviewed is not already true.
      // PATCH (pentest CRIT-6): the previous rule whitelisted the OUTER keys
      //   but allowed the inner `review` map to carry arbitrary keys (XSS /
      //   data-leak vector). We now constrain `review` to exactly
      //   {rating: int 1..5, comment: string <=500 chars, createdAt}.
      allow update: if isAdmin()
        || (
          isAuthenticated()
          && resource.data.userId == request.auth.uid
          && resource.data.get('hasReviewed', false) == false
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['hasReviewed', 'review'])
          && request.resource.data.review is map
          && request.resource.data.review.keys().hasOnly(['rating', 'comment', 'createdAt'])
          && request.resource.data.review.rating is int
          && request.resource.data.review.rating >= 1
          && request.resource.data.review.rating <= 5
          && request.resource.data.review.comment is string
          && request.resource.data.review.comment.size() <= 500
        )
        // PATCH (pentest BUG-1 / pass 6): owner-confirms-delivery path.
        // The admin shows a QR to the customer; the customer scans it on
        // their phone, lands on /valider-commande/[id], and presses
        // "Confirmer la Réception". This sets status=Livré + deliveredAt
        // ONLY when the order is in a delivery-eligible state and ONLY by
        // the order owner. Without this branch, the customer-side update
        // was rejected by the rule and the delivery confirmation UI was
        // dead.
        || (
          isAuthenticated()
          && resource.data.userId == request.auth.uid
          && resource.data.status in ['Acompte Reçu', 'En attente', 'En cours']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'deliveredAt'])
          && request.resource.data.status == "Livré"
          && request.resource.data.deliveredAt is string
        );

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // MENU — public read, admin write (unchanged behaviour, kept for completeness)
    // -------------------------------------------------------------------------
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // NEWSLETTER — closes C8
    // -------------------------------------------------------------------------
    match /newsletter/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt', 'source'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 200
        && request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && (
          !('source' in request.resource.data.keys())
          || (
            request.resource.data.source is string
            && request.resource.data.source.size() < 50
          )
        );

      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // PRESTATIONS — closes C9
    // -------------------------------------------------------------------------
    match /prestations/{docId} {
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly([
          'email', 'name', 'type', 'message', 'createdAt', 'phone', 'userId'
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200
        && request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && request.resource.data.name is string
        && request.resource.data.name.size() < 100
        && (
          !('type' in request.resource.data.keys())
          || request.resource.data.type in ['contact', 'prestation', 'event', 'catering']
        )
        && (
          !('message' in request.resource.data.keys())
          || (
            request.resource.data.message is string
            && request.resource.data.message.size() < 2000
          )
        );

      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // SETTINGS — closes C10
    //   Read is now auth-only (client snapshots /settings/global at boot).
    // PATCH (pentest H-4): hard 50KB cap on settings docs to prevent a
    //   compromised admin account (or buggy admin UI) from writing a giant
    //   document that gets fanned out to every authenticated client at boot.
    // -------------------------------------------------------------------------
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && request.resource.size < 50000;
    }
  }
}
